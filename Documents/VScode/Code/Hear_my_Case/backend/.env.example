# ========== DATABASE ==========
DATABASE_URL=postgresql+asyncpg://hear_user:hear_password@postgres:5432/hear_my_case
REDIS_URL=redis://redis:6379/0

# ========== API KEYS ==========
ANTHROPIC_API_KEY=sk-ant-xxxxx
SARVAM_API_KEY=xxxxx
BHASHINI_API_KEY=xxxxx
TWILIO_ACCOUNT_SID=xxxxx
TWILIO_AUTH_TOKEN=xxxxx

# ========== WHATSAPP ==========
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=xxxxx
WHATSAPP_BUSINESS_ACCOUNT_ID=xxxxx
WHATSAPP_API_TOKEN=xxxxx

# ========== AWS ==========
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_S3_BUCKET=hear-my-case-prod
AWS_REGION=ap-south-1

# ========== JWT ==========
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=7

# ========== OTP ==========
OTP_EXPIRY_MINUTES=5
MAX_OTP_ATTEMPTS=3

# ========== EMAIL/SMS ==========
MAIL_FROM=noreply@hearmycase.org
TWILIO_FROM_NUMBER=+1234567890

# ========== ENVIRONMENT ==========
ENVIRONMENT=development
DEBUG=True
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000"]

# ========== LOGGING ==========
LOG_LEVEL=INFO

# ========== DEMO MODE ==========
DEMO_MODE=True
AUTO_SEED_DEMO_DATA=True
